# ── Entity Validation ──────────────────────────────────────
# Strict filters to reject junk, merged, or malformed entities
# from SERP snippets while keeping real brands, products, and tools.

_ENTITY_SKIP_PREFIXES = (
    "the ", "a ", "an ", "top ", "best ", "our ", "your ", "we've ", "we ", "i ",
    "how ", "what ", "why ", "when ", "where ", "is ", "are ", "was ", "were ",
    "does ", "do ", "can ", "will ", "would ", "could ", "should ", "has ", "have ",
    "had ", "been ", "being ", "get ", "got ", "lets ", "let's ", "dont ", "don't ",
    "wont ", "won't ", "cant ", "can't ", "isnt ", "isn't ", "arent ", "aren't "
)

_BRAND_CORPUS = {
    "microsoft", "apple", "google", "amazon", "meta", "netflix", "spotify", "adobe",
    "oracle", "ibm", "intel", "amd", "nvidia", "samsung", "sony", "dell", "hp",
    "lenovo", "asus", "acer", "logitech", "corsair", "razer", "slack", "zoom",
    "github", "gitlab", "bitbucket", "atlassian", "salesforce", "hubspot", "shopify",
    "wordpress", "wix", "squarespace", "cloudflare", "digitalocean", "heroku",
    "canva", "figma", "sketch", "notion", "evernote", "trello", "asana", "jira",
    "clickup", "monday.com", "basecamp", "airtable", "mongodb", "postgresql",
    "mysql", "redis", "docker", "kubernetes", "linux", "ubuntu", "debian", "fedora",
    "windows", "macos", "android", "ios", "chrome", "firefox", "safari", "edge",
    "brave", "opera", "tor", "vpn", "expressvpn", "nordvpn", "protonvpn", "tailscale",
    "cloudron", "synology", "qnap", "raspberry pi", "arduino", "python", "javascript",
    "typescript", "rust", "golang", "react", "vue", "angular", "django", "flask",
    "spring", "laravel", "ruby", "rails", "aws", "azure", "gcp", "terraform",
    "ansible", "puppet", "chef", "jenkins", "circleci", "travisci", "datadog",
    "newrelic", "sentry", "grafana", "prometheus", "elasticsearch", "kibana",
    "screaming frog", "ahrefs", "semrush", "moz", "yoast", "rankmath",
}

# Words that appear capitalized in SERP text but are NEVER valid entities
_REJECT_WORDS = {
    "find", "learn", "discover", "search", "create", "build", "use", "try",
    "explore", "download", "watch", "read", "browse", "compare", "share",
    "start", "get", "view", "edit", "launch", "open", "run", "add", "manage",
    "configure", "select", "choose", "pick", "enter", "type", "click", "tap",
    "swipe", "drag", "drop", "upload", "import", "export", "sync", "backup",
    "restore", "reset", "delete", "remove", "hide", "show", "save", "publish",
    "schedule", "preview", "update", "upgrade", "install", "enable", "disable",
    "home", "blog", "pricing", "features", "docs", "support", "help", "faq",
    "about", "contact", "careers", "press", "investors",
    "today", "yesterday", "tomorrow", "now", "latest", "recent", "popular",
    "trending", "new", "old",
}

def _score_entity(name: str, keyword: str = "") -> int:
    """Score a candidate entity 0-100. Higher = more likely a real brand/product."""
    lower = name.lower().strip()
    # Auto-zero for reject words
    if lower in _REJECT_WORDS:
        return 0
    # Auto-zero for single generic words not in brand corpus
    if len(name.split()) == 1:
        if lower not in _BRAND_CORPUS and lower.strip(".,:;!?").isalpha():
            # Check if it's a common English word (verb/noun that isn't a brand)
            if len(lower) <= 8 and lower[0].isalpha() and re.match(r'^[a-z]+$', lower):
                return 0
    # 50pts — known brand
    if lower in _BRAND_CORPUS:
        return 50
    # 40pts — matches verified category
    if keyword:
        kw_lower = keyword.lower()
        for cat_key, entities in _VERIFIED_CATEGORIES.items():
            if cat_key in kw_lower:
                for ent in entities:
                    if ent.get("name", "").lower() == lower:
                        return 40
    # 30pts — proper multi-word name (Title Case, 2+ words)
    words = name.split()
    if len(words) >= 2 and all(w[0].isupper() for w in words if w):
        return 30
    # 20pts — single capitalized word, 6+ chars, not a common word
    if len(words) == 1 and len(name) >= 6:
        return 20
    return 0

def _validate_entity(name: str, keyword: str = "") -> str | None:
    """Return cleaned entity name if valid, None if junk."""
    raw = name.strip()
    if len(raw) < 3 or len(raw) > 50:
        return None
    lower = raw.lower()

    # Reject if it's the keyword itself
    if keyword and (lower == keyword.lower() or lower in keyword.lower()):
        return None

    # Reject merged-words (no spaces, multiple capitals): "Thebestpasswordmanagerstake"
    if " " not in raw and re.search(r'[a-z][A-Z]', raw):
        return None

    # Reject date patterns: "Updated April", "May 2026", etc.
    if re.search(r'(?i)\b(jan|feb|mar|apr|may|jun|jul|aug|sep|oct|nov|dec)\w*\s+\d{4}\b', lower):
        return None
    if re.search(r'(?i)\b(updated|published|modified|created)\s+(jan|feb|mar|apr|may|jun|jul|aug|sep|oct|nov|dec)', lower):
        return None

    # Reject single-letter tokens or purely numeric
    if re.match(r'^[\d\s,.-]+$', raw):
        return None
    if all(len(t) <= 2 for t in raw.split() if t):
        return None

    # Reject known navigation/junk fragments
    nav_patterns = [
        "skip to", "main content", "menu", "search", "login", "sign up", "sign in",
        "register", "subscribe", "contact", "about us", "privacy policy", "terms of",
        "cookie", "home page", "back to", "load more", "show more", "read more",
        "click here", "learn more", "get started", "try free", "start free",
        "free trial", "watch video", "see all", "view all", "browse all",
    ]
    if any(p in lower for p in nav_patterns):
        return None

    # Reject if starts with verb prefix (unless known brand, e.g. "ExpressVPN")
    starts_with_skip = any(lower.startswith(p) for p in _ENTITY_SKIP_PREFIXES)
    if starts_with_skip and raw not in _BRAND_CORPUS and raw.lower() not in _BRAND_CORPUS:
        return None

    # Reject random capitalization fragments (e.g. "Gunnar Kallstrom" — author names)
    is_author_pattern = bool(re.match(r'^[A-Z][a-z]+\s+[A-Z][a-z]+$', raw))
    if is_author_pattern:
        words = raw.split()
        # More aggressive: any two capitalized words likely an author unless it's a known brand
        if any(w.lower() in _BRAND_CORPUS for w in words):
            pass  # Allow "John Deere" style brand
        elif len(words) == 2 and all(len(w) > 2 for w in words):
            if raw.lower() not in _BRAND_CORPUS:
                return None  # Likely author name — reject regardless of length

    # Reject author bylines and attribution patterns
    if re.search(r'(?i)\b(by|written by|reviewed by|edited by)\s+[A-Z][a-z]', raw):
        return None

    # Reject text containing URLs or email-like patterns
    if re.search(r'https?://|www\.|\.com|\.org|\.net|\.io\b', lower):
        return None
    if re.search(r'[\w.+-]+@[\w-]+\.[\w.-]+', lower):
        return None

    # Reject mixed alphanumeric merged tokens (likely malformed brand): "D1gitalT00ls"
    if re.search(r'[a-zA-Z]+[0-9]+[a-zA-Z]', raw):
        return None

    # Reject entities that are just generic nouns (single word, common)
    common_nouns = {"tool", "software", "app", "application", "platform", "service",
                    "solution", "product", "system", "program", "suite", "package",
                    "utility", "feature", "option", "choice", "pick", "alternative",
                    "provider", "company", "vendor", "brand", "website", "site",
                    "extension", "plugin", "addon", "add-on", "integration",
                    "browser", "device", "desktop", "mobile", "online", "cloud"}
    if len(raw.split()) == 1 and raw.lower().strip(",.!?:;") in common_nouns:
        return None

    # Reject if too generic or contains generic words as main entity
    generic_words = {"guide", "review", "review", "tips", "tricks", "best", "top",
                     "free", "cheap", "affordable", "ultimate", "complete", "essential",
                     "simple", "easy", "quick", "fast", "advanced", "pro", "expert"}
    words = raw.lower().split()
    generic_count = sum(1 for w in words if w.strip(",:;.!?") in generic_words)
    if generic_count >= len(words) - 1 and len(words) > 1:
        return None

    return raw


def _get_verified_entities(category_hint: str, intent: str = "commercial") -> list[dict]:
    """Return verified entity dicts from knowledge base if keyword matches a known category.

    For news/informational/educational intents, only return entities if the category
    makes sense for that intent type. For commercial intents, return product entities.
    """
    cat_lower = category_hint.lower()
    for cat_key, entities in _VERIFIED_CATEGORIES.items():
        if cat_key in cat_lower:
            # For non-commercial intents, skip product entity injection
            # unless the keyword is still commercial-ish
            if intent in ("news", "informational", "educational", "trend_analysis", "investigative", "opinion"):
                # Only return entities if the keyword is not just a brand/product search
                # e.g. "bitcoin news" should not get password manager entities
                # but "best password manager" should (it's still commercial)
                # Check: if the keyword itself matches a product category, it's commercial intent
                product_triggers = ['best', 'top', 'review', 'vs', ' versus ', 'alternative', 'compare']
                if any(t in cat_lower for t in product_triggers):
                    return entities
                # For pure informational/news keywords (no product triggers), return empty
                # so the system doesn't force product entities into non-product content
                return []
            return entities
    return []


def _extract_keyword(text: str) -> str:
    # Order: most specific patterns first
    for pat in [
        r'Seed keyword:\s*"?([^"\n,]+)',
        r'keyword:\s*"?([^"\n,]+)',
        r'for:\s*"([^"]+)"',
        r'for:\s*([^\n,]+)',
        r'about:\s*"?([^"\n,]+)',
        r'about:\s*([^\n,]+)',
    ]:
        m = re.search(pat, text[:400], re.IGNORECASE)
        if m:
            return m.group(1).strip()
    # Last resort: extract from "Write a complete article about X" style
    m = re.search(r'article\s+(?:about|on|for)\s+["\']?([^"\'\n,.]+)', text[:400], re.IGNORECASE)
    if m:
        return m.group(1).strip()
    return "topic"

